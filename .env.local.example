# Supabase — projeyi açtıktan sonra Project Settings > API'den doldurun.
# Bu iki değer "anon" public key ile çalışır; server-side route handler üzerinden
# kullanıldığı için service_role key'e GEREK YOKTUR ve hiçbir zaman client'a konmaz.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Analytics — ID girilince otomatik aktif olur, boşsa hiçbir script yüklenmez.
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_FB_PIXEL_ID=

# Brevo — checklist e-postası + kişi listeleri. Boşsa Brevo devre dışı kalır
# (form yine çalışır, indirme + Supabase kaydı etkilenmez).
# API_KEY: Brevo > SMTP & API > API Keys | SENDER_EMAIL: doğrulanmış gönderen
# LIST_*: Contacts > Lists'teki liste ID'si (sayı)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Caner Doğru
BREVO_LIST_CHECKLIST=
BREVO_LIST_RONTGEN=

# Dosyayı .env.local olarak kopyalayın:  cp .env.local.example .env.local
